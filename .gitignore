# Canonical generated outputs
# dist/ is produced by `npm run build` and can be opened with `npm run app:open:dist`.
dist/
# build/ is produced by `npm run electron:build`; build/win-unpacked is the packaged app root.
build/
# Legacy workaround outputs. These are disposable; use `npm run clean:builds`.
build-new/
build-session*/
build-friction/

# Node
node_modules/

# Vendor fonts (Electron-only, generated by postinstall)
vendor/fonts/
# Kuromoji dictionary (17MB, generated by postinstall)
vendor/kuromoji-dict/

# Temporary
.tmp/
.cache/
tmp/

# Local helper scripts
scripts/gh-*.ps1

# DocFX build outputs
_site/
.docfx/

