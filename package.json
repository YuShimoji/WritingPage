{
  "name": "writingpage",
  "version": "0.3.29",
  "description": "Zen Writer - a minimal and stylish novel writing editor",
  "author": "YuShimoji",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "node scripts/copy-vendor.js",
    "dev": "node scripts/dev-server.js",
    "dev:two": "node scripts/run-two-servers.js",
    "build": "node scripts/build-dist.js",
    "app:open": "node scripts/open-built-app.js",
    "app:install": "npm run build && node scripts/install-start-menu-shortcut.js",
    "app:install:open": "npm run app:install && npm run app:open",
    "electron:dev": "electron electron/main.js",
    "electron:build": "electron-builder --win --dir",
    "electron:dist": "electron-builder --win",
    "test:smoke": "node scripts/dev-check.js",
    "test:ui:capture": "node scripts/capture-ui-verification.js",
    "test:ui:capture:build": "node scripts/capture-ui-verification.js --build --dist",
    "test:e2e:ui": "playwright test e2e/sidebar-layout.spec.js e2e/command-palette.spec.js e2e/gadgets.spec.js e2e/accessibility.spec.js",
    "test:e2e:stable": "playwright test e2e/collage.spec.js e2e/editor-settings.spec.js e2e/tags-smart-folders.spec.js --workers=1",
    "test:unit": "node --test test/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=line",
    "test:build:stable": "npm run lint:js:check && npm run test:smoke && npm run test:e2e:stable",
    "lint:js:check": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:md": "markdownlint **/*.md",
    "lint": "npm run lint:js:check && npm run lint:md",
    "lint:fix": "npm run lint:js:fix",
    "test": "npm run test:smoke && npm run test:e2e"
  },
  "build": {
    "appId": "com.zenwriter.app",
    "productName": "Zen Writer",
    "directories": {
      "output": "build"
    },
    "files": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "vendor/**/*",
      "favicon.svg",
      "manifest.webmanifest",
      "sw.js",
      "electron/**/*"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^8.57.0",
    "markdownlint-cli": "^0.40.0",
    "prettier": "^3.3.3",
    "puppeteer": "^24.31.0"
  },
  "dependencies": {
    "@fontsource/noto-serif-jp": "^5.0.0",
    "kuromoji": "^0.1.2",
    "lucide": "^0.577.0",
    "markdown-it": "^14.1.0",
    "morphdom": "^2.7.2",
    "turndown": "^7.2.2"
  }
}
